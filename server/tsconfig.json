{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "@bloodConnect/*": [
        "./src/*"
      ],
      "@common/*": [
        "../common/*"
      ]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "infrastructure/**/*.ts",
    "infrastructure/**/*.js",
    "../common/**/*.ts",
    "../common/**/*.js",
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}