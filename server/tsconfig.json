{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@common/*": ["../common/*"],
      "@src/*": ["./src/*"],
      "@infra/*": ["./infrastructure/*"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*", "infrastructure/**/*", "../common/**/*"],
  "exclude": ["node_modules", "dist"]
}
