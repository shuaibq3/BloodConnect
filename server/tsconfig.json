{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@common/*": ["../common/*"],
      "@src/*": ["src/*"],
      "@infra/*": ["infrastructure/*"]
    }
  },
  "include": ["src/**/*", "infrastructure/**/*", "../common/**/*"],
  "exclude": ["node_modules", "dist"]
}
