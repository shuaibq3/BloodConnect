{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "types": [
      "jest",
      "node"
    ]
  },
  "include": [
    "common/**/*.ts",
    "common/**/*.js",
    "server/**/*.ts",
    "server/**/*.js",
    "client/**/*.ts",
    "client/**/*.tsx",
    "client/**/*.js",
    "client/**/*.jsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}